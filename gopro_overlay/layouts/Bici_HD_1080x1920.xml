<layout>
	<translate x="50" y="60">	

		<translate x="0" y="650">
			<translate x="0"  y="75">
				<component type="zone-bar" metric="hr" min="90" max="194" 
					z1="136" z2="156" z3="175" 
					z0-rgb="66,176,112" z1-rgb="255,195,0" z2-rgb="230,126,34" z3-rgb="192,57,43" 
					zone-divider="90,90,90" outline="13,109,250,90" width="240" height="38"/>
			</translate>
			<translate x="125"  y="70">
				<component type="metric" metric="hr" dp="0" size="38" align="right"/>
			</translate>
			<translate x="145"  y="70">
				<component type="text" size="38" align="left" outline="0,0,0,100">BPM</component>
			</translate>
			<component type="icon" x="10" y="80" file="heartbeat.png" size="28"/>
		</translate>

		<translate x="0" y="700">
			<translate x="0"  y="75">
				<component type="bar" metric="speed" units="km/h" width="240" height="38" min="0" max="40" 
					outline="13,109,250,90" bar="235,24,0,100" h-pos="13,109,250" fill="66,73,73,85"/>
			</translate>
			<translate x="125"  y="70">
				<component type="metric" metric="speed" units="kph" dp="0" size="38" align="right"/>
			</translate>
			<translate x="145"  y="70">
				<component type="text" size="38" align="left" outline="0,0,0,100">KM/H</component>
			</translate>
			<component type="icon" x="10" y="80" file="speedometer-variant-tool-symbol.png" size="28"/>
		</translate>

		<translate x="0" y="750">
			<translate x="0"  y="75">
				<component type="bar" metric="cadence" width="240" height="38" min="0"  
					outline="13,109,250,90" bar="235,24,0,100" h-pos="13,109,250" fill="66,73,73,85"/>
			</translate>
			<translate x="125"  y="70">
				<component type="metric" metric="cadence" dp="0" size="38" align="right"/>
			</translate>
			<translate x="145"  y="70">
				<component type="text" size="38" align="left" outline="0,0,0,100">RPM</component>
			</translate>
			<component type="icon" x="10" y="80" file="gauge.png" size="28"/>
		</translate>

		<translate x="0" y="800">
			<translate x="0"  y="75">
				<component type="bar" metric="gradient" width="240" height="38" 
					outline="13,109,250,90" bar="235,24,0,100" h-pos="13,109,250" fill="66,73,73,85"/>
			</translate>
			<translate x="125"  y="70">
				<component type="metric" metric="gradient" dp="1" size="38" align="right"/>
			</translate>
			<translate x="145"  y="70">
				<component type="text" size="38" align="left" outline="0,0,0,100">DEG</component>
			</translate>
			<component type="icon" x="10" y="80" file="slope-triangle.png" size="28"/>
		</translate>
	</translate>
	
	<translate x="960" y="0">
		<translate x="-600"  y="40">
			<component type="datetime" format="%H:%M:%S" size="28" />
		</translate>
		<translate x="-500"  y="40">
			<component type="bar" metric="odo" units="km" width="1000" height="38" min="0" max="87" 
				outline="13,109,250,90" bar="235,24,0,100" h-pos="13,109,250" fill="66,73,73,85"/>
		</translate>
		<translate x="415"  y="38">
			<component type="metric" metric="odo" units="km" dp="1" size="33" align="right"/>
			<component type="text" size="28" y="5" rgb="125,125,125"> / 21.71</component>
		</translate>
		<component type="icon" x="340" y="45" file="ruler.png" size="22"/>
	</translate>

	<translate x="1500" y="25">
		<component type="cairo_circuit_map" size="400" fill="228,228,228" outline="0,0,0,80" loc-fill="255,255,255" loc-size="0.02" rotate="0" />
	</translate>

	<composite name="metrics" x="150" y="900"/>
</layout>
